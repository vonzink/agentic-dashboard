# Environment label shown in the top bar badge (local | dev | staging | prod)
VITE_ENV=local

# Set to 'true' to use the isolated mock data layer instead of the real API.
# A visible "MOCK DATA" badge appears in the top bar when active.
VITE_USE_MOCKS=false

# Auth: 'dev' (default — local identity switcher) or 'cognito' (hosted-UI
# PKCE login; values come from `terraform output` — see infra/README.md)
VITE_AUTH_MODE=dev
# VITE_COGNITO_DOMAIN=https://msfg-agentic-dev.auth.us-east-1.amazoncognito.com
# VITE_COGNITO_CLIENT_ID=
# VITE_COGNITO_REDIRECT_URI=         # defaults to window.location.origin
# VITE_COGNITO_GROUP_PREFIX=         # match the API's COGNITO_GROUP_PREFIX
