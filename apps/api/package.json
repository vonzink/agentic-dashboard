{
  "name": "@msfg/agentic-dashboard-api",
  "version": "0.1.0",
  "private": true,
  "description": "MSFG Agentic AI Dashboard API — compliance-first AI task/approval/audit service",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "build": "esbuild src/index.ts src/db/migrate.ts src/db/seed.ts --bundle --platform=node --target=node22 --format=esm --packages=external --outdir=dist",
    "start:prod": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "esbuild": "^0.28.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
