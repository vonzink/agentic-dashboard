# Copy to .env on the SERVER (never commit .env). Values marked (tf) come
# from `terraform output` in infra/ec2/terraform after apply.

# ---- host / TLS --------------------------------------------------------------
APP_HOSTNAME=agentic.zvzsolutions.com
ACME_EMAIL=you@zvzsolutions.com          # Let's Encrypt expiry notices

# ---- database (container-local Postgres) --------------------------------------
# Generate one: openssl rand -hex 24
POSTGRES_PASSWORD=

# ---- app ----------------------------------------------------------------------
APP_ENV=production
AUTH_MODE=cognito
COGNITO_USER_POOL_ID=                    # (tf) cognito_user_pool_id
COGNITO_CLIENT_ID=                       # (tf) cognito_client_id
COGNITO_REGION=us-east-1
COGNITO_DOMAIN=                          # (tf) cognito_domain — full https URL

# Solo-operator start: you must be able to review your own runs.
# Flip to true the day a second reviewer exists.
REQUIRE_DIFFERENT_REVIEWER=false
INTEGRATION_EXECUTION_ENABLED=false

# ---- model provider -------------------------------------------------------------
# mock (no spend) | anthropic | openai | deepseek — set the matching key.
MODEL_PROVIDER=mock
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# Match the ACTIVE provider's pricing so the usage panel is accurate:
# COST_PER_MTOK_IN=5
# COST_PER_MTOK_OUT=25

# ---- notifications ----------------------------------------------------------------
# Email alerts: review-needed, run-failed, budget thresholds. Log-only until
# BOTH SMTP_HOST and NOTIFY_EMAILS are set. Gmail works with an App Password
# (myaccount.google.com/apppasswords): SMTP_HOST=smtp.gmail.com, port 587.
# NOTIFY_EMAILS=you@zvzsolutions.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false            # true for implicit TLS (port 465)
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=                   # defaults to SMTP_USER
APP_BASE_URL=https://agentic.zvzsolutions.com   # links in notification emails

# ---- documents -------------------------------------------------------------------
# Default: the box's disk (docker volume). To use the optional S3 bucket
# instead, set S3_BUCKET (tf: documents_bucket) AND attach the policy
# (tf: documents_bucket_policy_arn) to this instance's IAM role.
# S3_BUCKET=
