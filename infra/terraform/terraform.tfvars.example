# Copy to terraform.tfvars and adjust. No secrets belong in this file —
# the Anthropic key is set directly in Secrets Manager after apply.

aws_region  = "us-east-1"
environment = "dev"

# Lock the dashboard down to office/VPN ranges before real use:
# allowed_ingress_cidrs = ["203.0.113.0/24"]

# Custom domain (Route 53 zone must already exist in this account).
# Certs, validation records, and A-aliases are created automatically.
route53_zone_name = "zvzsolutions.com"
app_hostname      = "agentic.zvzsolutions.com"
api_hostname      = "api.agentic.zvzsolutions.com"

cognito_domain_prefix = "zvz-agentic-dev" # must be globally unique
cognito_callback_urls = [
  "http://localhost:5173",
  "https://agentic.zvzsolutions.com",
]
cognito_logout_urls = [
  "http://localhost:5173",
  "https://agentic.zvzsolutions.com",
]

model_provider = "mock" # switch to "anthropic" after setting the key secret

# Prod hardening:
# environment              = "prod"
# db_multi_az              = true
# api_desired_count        = 2
