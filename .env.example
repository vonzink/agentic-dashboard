# ============================================================================
# MSFG Agentic AI Dashboard — environment template
# Copy to .env (gitignored) for local dev. NEVER commit real secrets.
# In AWS, secrets come from Secrets Manager / SSM Parameter Store — see
# docs/AGENTIC_DASHBOARD_AWS_DEPLOYMENT.md.
# ============================================================================

# --- API (apps/api) ---------------------------------------------------------
APP_ENV=local                 # local | dev | staging | production
PORT=4000

# Auth: 'dev' trusts x-user-email/x-user-role headers (LOCAL ONLY — refuses
# to start in production). 'cognito' verifies Bearer JWTs against the pool's
# JWKS; Cognito groups named viewer/operator/reviewer/admin (optionally
# prefixed) map to roles, highest wins, default viewer.
AUTH_MODE=dev
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# COGNITO_REGION=
# COGNITO_GROUP_PREFIX=        # e.g. 'msfg-' if groups are msfg-admin etc.

# Postgres. Leave unset for DB-less in-memory mode (data not persisted).
# Local docker: postgres://agentic:agentic_dev_password@localhost:5432/agentic_dashboard
DATABASE_URL=

# Model provider: 'mock' (default, no key) | 'anthropic' | 'openai' | 'deepseek'.
# One provider is active per deployment; set the matching key.
MODEL_PROVIDER=mock
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# Cost rates feed estimated_cost — set to match the ACTIVE provider's pricing:
# COST_PER_MTOK_IN=5          # USD per 1M input tokens
# COST_PER_MTOK_OUT=25

# Document storage: S3 in AWS (credentials via the task role / AWS chain),
# local disk in dev. Bytes never live in Postgres.
# S3_BUCKET=
# UPLOAD_DIR=.data/uploads     # local-disk fallback location (gitignored)

# Compliance switches
REQUIRE_DIFFERENT_REVIEWER=false   # set true outside local dev
INTEGRATION_EXECUTION_ENABLED=false # false = propose-only mode (MVP default)

# Email notifications (review-needed / run-failed / budget alerts).
# Log-only unless BOTH SMTP_HOST and NOTIFY_EMAILS are set. Bodies carry
# task/workflow metadata only — never AI output content.
# NOTIFY_EMAILS=you@example.com,reviewer@example.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false            # true for implicit TLS (port 465)
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=                   # defaults to SMTP_USER
# APP_BASE_URL=                # e.g. https://agentic.zvzsolutions.com — adds links to emails

# --- Web (apps/web — uses its own apps/web/.env, see apps/web/.env.example) --
# VITE_ENV=local
# VITE_USE_MOCKS=false
