# ============================================================================
# MSFG Agentic AI Dashboard — environment template
# Copy to .env (gitignored) for local dev. NEVER commit real secrets.
# In AWS, secrets come from Secrets Manager / SSM Parameter Store — see
# docs/AGENTIC_DASHBOARD_AWS_DEPLOYMENT.md.
# ============================================================================

# --- API (apps/api) ---------------------------------------------------------
APP_ENV=local                 # local | dev | staging | production
PORT=4000

# Auth: 'dev' trusts x-user-email/x-user-role headers (LOCAL ONLY — refuses
# to start in production). 'cognito' verifies Bearer JWTs against the pool's
# JWKS; Cognito groups named viewer/operator/reviewer/admin (optionally
# prefixed) map to roles, highest wins, default viewer.
AUTH_MODE=dev
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# COGNITO_REGION=
# COGNITO_GROUP_PREFIX=        # e.g. 'msfg-' if groups are msfg-admin etc.

# Postgres. Leave unset for DB-less in-memory mode (data not persisted).
# Local docker: postgres://agentic:agentic_dev_password@localhost:5432/agentic_dashboard
DATABASE_URL=

# Model provider: 'mock' (default, no key needed) or 'anthropic'
MODEL_PROVIDER=mock
# ANTHROPIC_API_KEY=          # required only when MODEL_PROVIDER=anthropic
# ANTHROPIC_MODEL=claude-opus-4-8
# COST_PER_MTOK_IN=5          # USD per 1M input tokens (for estimated_cost)
# COST_PER_MTOK_OUT=25

# Compliance switches
REQUIRE_DIFFERENT_REVIEWER=false   # set true outside local dev
INTEGRATION_EXECUTION_ENABLED=false # false = propose-only mode (MVP default)

# --- Web (apps/web — uses its own apps/web/.env, see apps/web/.env.example) --
# VITE_ENV=local
# VITE_USE_MOCKS=false
